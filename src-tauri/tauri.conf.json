{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-tauri-docs-v2/main/content/docs/reference/configuring-tauri-schema-v2.json",
  "productName": "械式微信多开器",
  "version": "0.1.0",
  "identifier": "com.xieshi.wechat-multi",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "械式微信多开器 - by aaaa",
        "width": 960,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}